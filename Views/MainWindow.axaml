<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:JobTracker.ViewModels"
		xmlns:jobtracker="using:jobtracker"
		x:Class="JobTracker.Views.MainWindow"
		x:DataType="vm:MainViewModel"
		Title="JobTracker"
		Width="640" Height="640"
		Icon="/Assets/alarm-clock.ico"
		CanResize="False"
		WindowStartupLocation="CenterScreen"
		Background="#ffedce">

	<DockPanel>
		<jobtracker:Controls DockPanel.Dock="Bottom" HorizontalAlignment="Stretch" />
		<jobtracker:Content />
	</DockPanel>
</Window>