<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:JobTracker.ViewModels"
		xmlns:jobtracker="using:JobTracker"
		x:Class="JobTracker.Views.MainWindow"
		x:DataType="vm:MainViewModel"
		Title="JobTracker"
		Width="640" Height="640"
		Icon="/Assets/alarm-clock.ico"
		CanResize="False"
		WindowStartupLocation="CenterScreen"
		Background="#ffedce">

	<Panel>
		<DockPanel>
			<jobtracker:Controls DockPanel.Dock="Bottom" HorizontalAlignment="Stretch" />
			<jobtracker:Content />
		</DockPanel>

		<Border IsVisible="{Binding IsConfirmOpen}" Background="#80000000" ZIndex="100">
			<Border Background="#ffedce" CornerRadius="8" Padding="24" 
			HorizontalAlignment="Center" VerticalAlignment="Center" 
			MaxWidth="400" BoxShadow="0 4 8 0 #40000000">
			    <StackPanel Spacing="16">
				<TextBlock Text="Destructive Action" FontSize="20" FontWeight="Bold"/>
				<TextBlock Text="{Binding ConfirmMessage}" TextWrapping="Wrap"/>
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
				    <Button Content="Cancel" Command="{Binding CancelActionCommand}" />
				    <Button Content="Confirm" Command="{Binding ConfirmActionCommand}" 
					    Classes="button-discard"
					    Background="#FF8383"/>
				</StackPanel>
			    </StackPanel>
			</Border>
		</Border>
	</Panel>
</Window>
